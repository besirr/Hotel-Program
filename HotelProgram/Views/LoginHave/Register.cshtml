@model HotelProgram.Models.RegisterModels
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol</title>
    <link rel="stylesheet" href="~/css/Register.css" />
</head>
<body>

    <div class="register-card">

        <div class="card-header">
            <div class="logo-mark">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3 9.75L12 3l9 6.75V21a1 1 0 01-1 1H4a1 1 0 01-1-1V9.75z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 21V12h6v9" />
                </svg>
            </div>
            <h1 class="register-title">Hesap Oluştur</h1>
            <p class="register-sub">Sisteme kayıt olmak için formu doldurun</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="errorBox">
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                </svg>
                @ViewBag.Error
            </div>
        }
        @if (ViewBag.Success != null)
        {
            <div class="successBox">
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                @ViewBag.Success
            </div>
        }

        <form asp-action="Register" asp-controller="LoginHave" method="post" class="register-form">

            <div class="field-group">
                <label class="field-label" asp-for="Username">Kullanıcı Adı</label>
                <div class="field-wrap">
                    <span class="field-icon">
                        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zm-4 7a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </span>
                    <input asp-for="Username" placeholder="Kullanıcı adınızı girin" autocomplete="username" required />
                </div>
                <span asp-validation-for="Username" class="field-error"></span>
            </div>

            <div class="field-group">
                <label class="field-label" asp-for="UsernameLastname">İsim Soyisim</label>
                <div class="field-wrap">
                    <span class="field-icon">
                        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M5.121 17.804A8.966 8.966 0 0112 15c2.21 0 4.231.8 5.879 2.118M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </span>
                    <input asp-for="UsernameLastname" placeholder="Adınız ve soyadınız" autocomplete="name" required />
                </div>
                <span asp-validation-for="UsernameLastname" class="field-error"></span>
            </div>

            <div class="field-group">
                <label class="field-label" asp-for="TC">T.C. Kimlik No</label>
                <div class="field-wrap">
                    <span class="field-icon">
                        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0" />
                        </svg>
                    </span>
                    <input asp-for="TC"
                           maxlength="11"
                           inputmode="numeric"
                           pattern="[0-9]{11}"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                           placeholder="11 haneli TC kimlik numaranız"
                           autocomplete="off"
                           required />
                </div>
                <span asp-validation-for="TC" class="field-error"></span>
            </div>

            <div class="field-group">
                <label class="field-label" asp-for="Password">Şifre</label>
                <div class="field-wrap">
                    <span class="field-icon">
                        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </span>
                    <input asp-for="Password"
                           type="password"
                           id="passwordInput"
                           minlength="6"
                           placeholder="En az 6 karakter"
                           autocomplete="new-password"
                           required />
                    <button type="button" class="toggle-password" onclick="togglePassword()" aria-label="Şifreyi göster/gizle" tabindex="-1">
                        <svg id="eyeIcon" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="field-group">
                <label class="field-label" asp-for="RoleID">Ünvan</label>
                <div class="field-wrap select-wrap">
                    <span class="field-icon">
                        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6a4 4 0 11-8 0 4 4 0 018 0zm-4 12v-1" />
                        </svg>
                    </span>
                    <select asp-for="RoleID">
                        <option value="1">Müdür</option>
                        <option value="2">Oda Temizlik Görevlisi</option>
                    </select>
                    <span class="select-arrow">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                </div>
            </div>

            <button type="submit" class="registerButton">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                </svg>
                Kayıt Ol
            </button>

            <div class="divider"><span>veya</span></div>

            <a href="/LoginHave/Back" class="back-link">← Geri Dön</a>

        </form>
    </div>

    <script src="~/js/registerr.js"></script>

</body>
</html>
